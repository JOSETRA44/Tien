<resources>
    <!-- Base window theme. Compose handles all visual theming;
         this XML only sets the pre-render window background and hides the action bar. -->
    <style name="Theme.Tien" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
